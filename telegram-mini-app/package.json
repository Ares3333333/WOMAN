{
  "name": "sora-calm-telegram",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:deploy": "npm run build && cd server && npm install --omit=dev",
    "preview": "vite preview",
    "test": "vitest run",
    "server:dev": "npm run dev --prefix server",
    "server:start": "npm start --prefix server",
    "dev:stack": "concurrently -n vite,api -c cyan,magenta \"npm run dev\" \"npm run server:dev\""
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.34",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.5"
  }
}
