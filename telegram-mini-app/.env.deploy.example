# =============================================================================
# ДЕПЛОЙ НА СЕРВЕР (Timeweb VPS / Ubuntu)
# =============================================================================
#
# 1) Скопируй этот файл на сервер как:
#      /var/www/sora/.env.build
#    и раскомментируй / заполни строку VITE (обязательна для сборки фронта):
#
export VITE_TELEGRAM_BOT="https://t.me/ТВОЙ_БОТ"
#
# Опционально, если API на другом домене (обычно не нужно — один сервер):
# export VITE_API_URL="https://api.example.com"
#
# 2) Отдельно создай файл с секретами бэкенда (НЕ коммить в Git):
#      /var/www/sora/telegram-mini-app/server/.env
#
#    Скопируй шаблон:
#      cp telegram-mini-app/server/.env.example telegram-mini-app/server/.env
#    и заполни BOT_TOKEN, WEB_APP_URL, ADMIN_TELEGRAM_IDS и т.д.
#
# =============================================================================
