# Токен от @BotFather
BOT_TOKEN=123456:ABC-DEF...

# Публичный HTTPS URL мини-приложения (как в браузере, со слэшем в конце не обязательно)
WEB_APP_URL=https://sora.example.com

# Порт: в коде по умолчанию 3000, если переменная не задана (Timeweb задаёт PORT сам).
# Для VPS с nginx на 3001 оставь PORT=3001.
PORT=3001

# Telegram ID админов через запятую — команды /grant и /revoke (ответом на сообщение юзера)
ADMIN_TELEGRAM_IDS=123456789

# Если фронт на другом домене — перечисли origin через запятую. Пусто = разрешить любой (удобно на старте)
# CORS_ORIGIN=https://sora.example.com
