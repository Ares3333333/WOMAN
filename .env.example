# --- Local dev (default): SQLite file next to schema — no Docker ---
DATABASE_URL="file:./dev.db"

# Production: use PostgreSQL instead, e.g.
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/sora_calm?schema=public"

# Auth.js / NextAuth — auto-created on first npm run dev if missing
AUTH_SECRET="replace-with-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Optional: comma-separated emails allowed to access /admin (empty = any signed-in user in dev)
ADMIN_EMAILS=""

# AI text generation — omit for deterministic mock drafts
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# TTS — mock by default; set USE_OPENAI_TTS=true with OPENAI_API_KEY for OpenAI speech
USE_OPENAI_TTS="false"
OPENAI_TTS_MODEL="tts-1"

# Player: reads full script aloud (recommended until you upload MP3 per session)
NEXT_PUBLIC_USE_BROWSER_TTS="true"

# Local dev: open /sign-in and you are signed in as premium without typing (set false in production)
DEV_SKIP_LOGIN="true"
# Optional: which seeded user to use for quick login (default premium@soracalm.app)
# DEV_LOGIN_EMAIL="premium@soracalm.app"

# Stripe placeholders (post-MVP wiring)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_PREMIUM=""
STRIPE_PRICE_ADDON=""
